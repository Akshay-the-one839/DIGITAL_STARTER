 int new_value()
 {
    if(update_flag)
    {
       update_flag=0;
       for(int i=0;i<3;i++)
       {
          float v_adc=adc_values[i]*4.98/1023.0;
          voltages[i]=(int16)(v_adc*SCALE_FACTOR);
          adc_values[i]=0;
       }
       
       for(i=3;i<6;i++)
       {
          float adc_voltage=adc_values[i]*5.0/1023.0;
          currents[i-3] = (adc_voltage / 0.059) * 0.64;
          adc_values[i]=1023;
       }
       change();
       return 0;
    }
    
    return 1;
 }
 
 
